{
    "position": "bottom",
    "height": 32,
    "modules-left": ["sway/workspaces", "sway/mode"],
    "modules-center": ["sway/window"],
    "modules-right": ["custom/weather", "idle_inhibitor", "keyboard-state", "pulseaudio", "network", "battery", "custom/disk", "custom/kernel", "custom/systemd", "custom/update", "clock", "tray"],
    "sway/workspaces": {
         "disable-scroll": true
    },
    "sway/window": {
        "icon": false,
        "max-length": 48
    },
    "sway/mode": {
        "format": "<span foreground=\"red\" background=\"#202020\">{}</span>"
    },
    "idle_inhibitor": {
        "start-activated": true,
        "format": "{icon}",
        "format-icons": {
            "activated": "пБЃ",
            "deactivated": "пБ∞"
        }
    },
    "tray": {
        "icon-size": 24,
        "spacing": 10
    },
    "clock": {
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%Y-%m-%d}",
        "calendar": {
            "format": {
                "today": "<span color='#66aaff'><b><u>{}</u></b></span>"
            }
        }
    },
    "cpu": {
        "format": "пТЉ {usage}%",
        "tooltip": false
    },
    "memory": {
        "format": "оњЕ {}%"
    },
    "battery": {
        "states": {
            // "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": "оЇ° {capacity}%",
        "format-plugged": "пЗ¶ {capacity}%",
        "format-alt": "{icon} {time}",
        "format-icons": ["пЙД", "пЙГ", "пЙВ", "пЙБ", "пЙА"]
    },
    "network": {
        "tooltip-format-ethernet": "Interface: {ifname}\nUpload: {bandwidthUpBytes}\nDownload: {bandwidthDownBytes}",
        "tooltip-format-wifi": "Interface: {ifname}\nSSID: {essid}\nStrength: {signaldBm} dBm\nFrequency: {frequency} GHz\nUpload: {bandwidthUpBytes}\nDownload: {bandwidthDownBytes}",
        "tooltip-format-disconnected": "",
        "format-wifi": "пЗЂ  {signalStrength}%",
        "format-ethernet": "ољД",
        "format-linked": "ољД {ifname} (No IP)",
        "format-disconnected": "пДІ",
        "format-alt": "{ifname}: {ipaddr}/{cidr}"
    },
    "pulseaudio": {
        "scroll-step": 5, // %, can be a float
        "format": "{icon} {volume}%",
        "format-alt": "{format_source}",
        "format-bluetooth": "{icon}пКФ {volume}%",
        "format-bluetooth-muted": "у∞Чњ {icon}пКФ",
        "format-muted": "пС¶ {volume}%",
        "format-source": "пД∞ {volume}%",
        "format-source-muted": "пД± {volume}%",
        "format-icons": {
            "headphone": "пА•",
            "hands-free": "оєЩ",
            "headset": "оєЩ",
            "phone": "пВХ",
            "portable": "пВХ",
            "car": "пЖє",
            "default": ["пА¶", "пАІ", "пА®"]
        }
    },
    "keyboard-state": {
        "capslock": true,
        "format": {
            "capslock": "{icon}"
        },
        "format-icons": {
            "locked": "CAPS",
            "unlocked": ""
        }
    },
    "custom/weather": {
        "interval": 300,
        "return-type": "json",
        "exec": "source $HOME/.config/waybar/envs && $HOME/.config/waybar/scripts/weather 2>/dev/null"
    },
    "custom/kernel": {
        "interval": 60,
        "exec": "$HOME/.config/waybar/scripts/kernel-version 2>/dev/null"
    },
    "custom/systemd": {
        "interval": 60,
        "exec": "$HOME/.config/waybar/scripts/systemd 2>/dev/null"
    },
    "custom/update": {
        "interval": 3600,
        "return-type": "json",
        "signal": 2,
        "exec": "$HOME/.config/waybar/scripts/arch-update 2>/dev/null"
    },
    "custom/disk": {
        "interval": 60,
        "return-type": "json",
        "exec": "$HOME/.config/waybar/scripts/disk 2>/dev/null"
    }
}
// vim: ft=json
